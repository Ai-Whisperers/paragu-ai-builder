{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pestanas",
  "title": "Lashes & Brows Studio Business Input Schema",
  "description": "Additional fields required from lash and brow studios beyond the base schema",
  "allOf": [{ "$ref": "base-business" }],
  "properties": {
    "numberOfTechnicians": { "type": "integer", "minimum": 1 },
    "serviceCategories": {
      "type": "array",
      "items": { "type": "string", "enum": ["pestanas", "cejas", "microblading", "lifting"] }
    },
    "portfolioTypes": {
      "type": "array",
      "items": { "type": "string", "enum": ["pestanas", "cejas", "microblading"] }
    }
  },
  "inputForm": {
    "priority1": ["businessName", "contact.phone", "location.address", "location.city", "services", "portfolio.images"],
    "priority2": ["branding.logoUrl", "hours", "contact.instagram", "contact.whatsapp"],
    "priority3": ["seo.googleBusinessProfileUrl", "branding.referenceWebsites", "faq"]
  }
}
