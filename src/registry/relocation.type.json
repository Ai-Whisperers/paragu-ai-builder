{
  "id": "relocation",
  "nameEs": "Servicios de Reubicación",
  "nameEn": "Relocation Services",

  "tokens": "relocation",

  "pages": {
    "homepage": {
      "sections": ["header", "hero", "trustBadges", "packageGrid", "processSteps", "targetMarkets", "faqPreview", "leadForm", "footer"],
      "requiredSections": ["header", "hero", "packageGrid", "leadForm", "footer"]
    },
    "paquetes": {
      "sections": ["header", "packageGrid", "packageCompare", "trustBadges", "leadForm", "footer"],
      "requiredSections": ["header", "packageGrid", "footer"]
    },
    "paquete-detalle": {
      "sections": ["header", "hero", "packageDetail", "processSteps", "faq", "leadForm", "footer"],
      "requiredSections": ["header", "packageDetail", "leadForm", "footer"]
    },
    "proceso": {
      "sections": ["header", "processSteps", "trustBadges", "leadForm", "footer"],
      "requiredSections": ["header", "processSteps", "footer"]
    },
    "faq": {
      "sections": ["header", "faq", "leadForm", "footer"],
      "requiredSections": ["header", "faq", "footer"]
    },
    "blog": {
      "sections": ["header", "blogList", "footer"],
      "requiredSections": ["header", "blogList", "footer"]
    },
    "blog-post": {
      "sections": ["header", "blogPost", "ctaBanner", "footer"],
      "requiredSections": ["header", "blogPost", "footer"]
    },
    "contacto": {
      "sections": ["header", "leadForm", "contactSplit", "footer"],
      "requiredSections": ["header", "leadForm", "footer"]
    },
    "legal": {
      "sections": ["header", "legalPage", "footer"],
      "requiredSections": ["header", "legalPage", "footer"]
    }
  },

  "features": {
    "multilingual": { "enabled": true, "locales": ["es", "en", "nl", "de"], "defaultLocale": "es" },
    "leadCapture": {
      "enabled": true,
      "fields": [
        { "name": "name", "type": "text", "required": true },
        { "name": "email", "type": "email", "required": true },
        { "name": "phone", "type": "tel", "required": false },
        { "name": "country", "type": "text", "required": false },
        { "name": "packageInterest", "type": "select", "required": false, "optionsFromSchema": "packages[].id" },
        { "name": "message", "type": "textarea", "required": false }
      ],
      "honeypot": true,
      "minTimeToSubmitMs": 3000,
      "captcha": "optional",
      "notifyEmail": true,
      "consentRequired": true
    },
    "blog": { "enabled": true, "localesEnabled": ["es", "en"], "postsPerIndex": 9, "rss": true },
    "pricingDisplay": { "enabled": true, "mode": "from_or_consult", "currency": "USD" },
    "trustSignals": { "enabled": true },
    "whatsappFloat": { "enabled": true, "defaultMessageKey": "whatsapp.defaultMessage" },
    "googleMapsEmbed": { "enabled": true },
    "onlineBooking": { "enabled": false },
    "portfolio": { "enabled": false },
    "staffProfiles": { "enabled": false },
    "beforeAfter": { "enabled": false }
  },

  "serviceCategories": ["residencia", "empresa", "inversion", "tierras"],

  "targetAudience": {
    "primary": "High-net-worth Europeans (Dutch, German, Scandinavian) seeking Paraguay residency and investment",
    "secondary": "Latin American entrepreneurs, retirees, families relocating for tax/lifestyle reasons"
  },

  "seo": {
    "titleTemplate": "{{businessName}} - Relocation to Paraguay | Residency, Business, Investment",
    "descriptionTemplate": "End-to-end relocation to Paraguay: residency, company incorporation, banking and investment. Tailored programs for European investors and families.",
    "schemaType": "ProfessionalService",
    "keywords": [
      "Paraguay residency",
      "relocate to Paraguay",
      "Paraguay investor visa",
      "Paraguay company incorporation",
      "residencia Paraguay",
      "Umzug nach Paraguay",
      "verhuizen naar Paraguay"
    ]
  },

  "nav": {
    "items": [
      { "key": "home", "href": "/" },
      { "key": "packages", "href": "/paquetes" },
      { "key": "process", "href": "/proceso" },
      { "key": "faq", "href": "/faq" },
      { "key": "blog", "href": "/blog" },
      { "key": "contact", "href": "/contacto" }
    ],
    "cta": { "textKey": "nav.cta", "action": "lead" }
  },

  "hero": {
    "style": "image-overlay",
    "headlineKey": "hero.headline",
    "subheadlineKey": "hero.subheadline",
    "ctaPrimary": { "textKey": "hero.ctaPrimary", "action": "lead" },
    "ctaSecondary": { "textKey": "hero.ctaSecondary", "action": "scrollTo:packageGrid" }
  }
}
