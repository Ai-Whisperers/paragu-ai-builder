{
  "name": "Relocation Services",
  "extends": "base",
  "theme": "light",
  "mood": ["premium", "trust", "professional", "international"],

  "palettes": {
    "optionA": {
      "name": "Navy & Gold Premium",
      "colors": {
        "primary": "#1B2A4A",
        "secondary": "#C9A96E",
        "accent": "#E8F0FE",
        "background": "#FAFBFD",
        "surface": "#FFFFFF",
        "surfaceLight": "#F5F7FA",
        "text": "#1A1A2E",
        "textLight": "#8892A0",
        "textMuted": "#5A6577",
        "success": "#16A34A",
        "error": "#DC2626",
        "warning": "#F59E0B",
        "secondaryHover": "#A88A4E"
      }
    },
    "optionB": {
      "name": "Dark Trust",
      "colors": {
        "primary": "#0D1B2A",
        "secondary": "#D4AF37",
        "accent": "#415A77",
        "background": "#0D1B2A",
        "surface": "#1B2838",
        "surfaceLight": "#253545",
        "text": "#E0E1DD",
        "textLight": "#778DA9",
        "textMuted": "#A0A4A8",
        "success": "#22C55E",
        "error": "#EF4444",
        "warning": "#F59E0B",
        "secondaryHover": "#B89A2E"
      }
    }
  },

  "defaultPalette": "optionA",

  "typography": {
    "heading": "'Playfair Display', serif",
    "body": "'Inter', sans-serif",
    "accent": "'Cormorant Garamond', serif",
    "headingWeight": "700",
    "bodyWeight": "400",
    "textTransform": "none"
  },

  "googleFonts": ["Playfair+Display:wght@400;700;900", "Inter:wght@300;400;500;600;700", "Cormorant+Garamond:wght@400;500;600"],

  "borderRadius": "md",
  "buttonStyle": "premium",

  "components": {
    "button": {
      "padding": "14px 32px",
      "borderRadius": "6px",
      "textTransform": "none",
      "fontWeight": "600"
    },
    "programComparison": {
      "columns": 2,
      "highlightedBorderColor": "secondary",
      "showPrices": true,
      "checkmarkColor": "secondary"
    },
    "processTimeline": {
      "orientation": "vertical",
      "lineColor": "secondary",
      "stepSize": "3rem",
      "showDuration": true
    }
  }
}
