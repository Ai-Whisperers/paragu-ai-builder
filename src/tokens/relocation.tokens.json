{
  "extends": "base",
  "theme": "light",
  "mood": ["premium", "trust", "professional", "international"],

  "colorPalettes": {
    "optionA": {
      "name": "Navy & Gold Premium",
      "primary": "#1B2A4A",
      "primaryLight": "#2C3E6B",
      "primaryDark": "#0F1A2E",
      "secondary": "#C9A96E",
      "secondaryLight": "#D4BC8E",
      "secondaryDark": "#A88A4E",
      "accent": "#E8F0FE",
      "background": "#FAFBFD",
      "surface": "#FFFFFF",
      "surfaceLight": "#F5F7FA",
      "text": "#1A1A2E",
      "textMuted": "#5A6577",
      "textLight": "#8892A0",
      "border": "#E2E8F0",
      "success": "#16A34A",
      "error": "#DC2626"
    },
    "optionB": {
      "name": "Dark Trust",
      "primary": "#0D1B2A",
      "primaryLight": "#1B2838",
      "primaryDark": "#060F18",
      "secondary": "#D4AF37",
      "secondaryLight": "#E0C45C",
      "secondaryDark": "#B89A2E",
      "accent": "#415A77",
      "background": "#0D1B2A",
      "surface": "#1B2838",
      "surfaceLight": "#253545",
      "text": "#E0E1DD",
      "textMuted": "#A0A4A8",
      "textLight": "#778DA9",
      "border": "#2A3A4A",
      "success": "#22C55E",
      "error": "#EF4444"
    }
  },

  "selectedPalette": "optionA",

  "typography": {
    "headingFont": "Playfair Display",
    "bodyFont": "Inter",
    "accentFont": "Cormorant Garamond",
    "headingWeight": "700",
    "bodyWeight": "400",
    "headingSizes": {
      "h1": "3rem",
      "h2": "2.25rem",
      "h3": "1.5rem",
      "h4": "1.25rem"
    },
    "bodySizes": {
      "base": "1rem",
      "lg": "1.125rem",
      "sm": "0.875rem"
    },
    "lineHeights": {
      "heading": "1.2",
      "body": "1.7"
    }
  },

  "spacing": {
    "sectionPadding": "5rem",
    "containerMax": "1200px",
    "cardPadding": "2rem"
  },

  "components": {
    "button": {
      "style": "premium",
      "borderRadius": "0.375rem",
      "paddingX": "2rem",
      "paddingY": "0.875rem"
    },
    "card": {
      "borderRadius": "0.75rem",
      "shadow": "0 4px 20px rgba(27,42,74,0.08)",
      "hoverShadow": "0 8px 30px rgba(27,42,74,0.15)"
    },
    "programComparison": {
      "columns": 2,
      "highlightedBorderColor": "secondary",
      "showPrices": true,
      "checkmarkColor": "secondary"
    },
    "processTimeline": {
      "orientation": "vertical",
      "lineColor": "secondary",
      "stepSize": "3rem",
      "showDuration": true
    }
  }
}
