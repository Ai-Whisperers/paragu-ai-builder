{
  "name": "Pestanas (Lashes & Brows)",
  "extends": "base",
  "theme": "light",
  "mood": ["glamorous", "feminine", "delicate", "Instagram-worthy"],

  "palettes": {
    "optionA": {
      "name": "Glamour Rose",
      "colors": {
        "primary": "#1a1a1a",
        "secondary": "#c4788b",
        "background": "#fdf8f9",
        "surface": "#ffffff",
        "text": "#2d2d2d",
        "textLight": "#777777",
        "accent": "#d4a574",
        "success": "#4a7c59",
        "error": "#c0392b",
        "secondaryHover": "#b0687a"
      }
    },
    "optionB": {
      "name": "Midnight Glam",
      "colors": {
        "primary": "#0d0d0d",
        "secondary": "#b8860b",
        "background": "#f5f3f0",
        "surface": "#ffffff",
        "text": "#1a1a1a",
        "textLight": "#555555",
        "accent": "#c9a96e",
        "success": "#4a7c59",
        "error": "#c0392b"
      }
    }
  },

  "defaultPalette": "optionA",

  "typography": {
    "heading": "'Cormorant Garamond', serif",
    "body": "'Nunito Sans', sans-serif",
    "accent": "'Cormorant Garamond', serif",
    "headingWeight": "700",
    "bodyWeight": "400",
    "headingStyle": "normal",
    "textTransform": "none"
  },

  "googleFonts": ["Cormorant+Garamond:wght@400;500;600;700", "Nunito+Sans:wght@300;400;500;600"],

  "borderRadius": "md",
  "buttonStyle": "rounded-md",

  "components": {
    "button": {
      "padding": "12px 24px",
      "borderRadius": "8px",
      "hoverTranslateY": "-2px"
    },
    "serviceCard": {
      "borderRadius": "12px",
      "hoverTranslateY": "-4px",
      "imageRatio": "4:5"
    },
    "teamCard": {
      "imageShape": "circle",
      "imageSize": "150px"
    },
    "gallery": {
      "layout": "masonry"
    }
  }
}
