# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git

# =============================================================================
# Supabase Configuration (Required)
# =============================================================================
# Get these from your Supabase project dashboard: https://app.supabase.com
# Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# Cloudflare Pages (Required for deployment)
# =============================================================================
# These are automatically set in Cloudflare Pages dashboard
# No need to set locally unless testing Cloudflare-specific features

# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_PAGES_PROJECT_NAME=

# =============================================================================
# Site Configuration
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://paragu-ai.pages.dev
NEXT_PUBLIC_SITE_NAME=Paragu-AI

# =============================================================================
# MercadoPago Configuration (Required for payments - Phase 4)
# =============================================================================
# Get from MercadoPago dashboard: https://www.mercadopago.com/developers
# Use test credentials for development, production for live

MERCADOPAGO_PUBLIC_KEY=TEST-or-APP-your-public-key
MERCADOPAGO_ACCESS_TOKEN=TEST-or-APP-your-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# Optional: Analytics & Monitoring
# =============================================================================
# Google Analytics 4
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics (privacy-friendly alternative)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# =============================================================================
# Optional: External Integrations
# =============================================================================
# Twilio (for phone validation - Workstream B)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# Resend (for transactional emails)
# RESEND_API_KEY=

# Cal.com or Calendly (for booking meetings)
# CAL_API_KEY=
# CALENDLY_WEBHOOK_SECRET=

# =============================================================================
# Development Only
# =============================================================================
# Skip type checking during build (faster, but less safe)
# SKIP_TYPE_CHECK=false

# Enable debug logging
# DEBUG=true

# Supabase local development (if using CLI)
# SUPABASE_LOCAL=true
