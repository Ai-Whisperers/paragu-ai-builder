{
  "name": "paragu-ai-builder",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,css}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "npx @opennextjs/cloudflare build",
    "start": "next start",
    "preview:cloudflare": "npx wrangler dev",
    "deploy:cloudflare": "npm run build:cloudflare && npx wrangler deploy",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "test": "npm run test:unit",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run tests/unit --coverage",
    "test:integration": "vitest run tests/integration --coverage",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:coverage": "vitest run --coverage",
    "test:coverage:html": "vitest run --coverage --coverage.reporter=html",
    "validate:schemas": "npx tsx scripts/validate-schemas.ts",
    "validate:tokens": "npx tsx scripts/validate-tokens.ts",
    "validate:sites": "npx tsx scripts/validate-sites.ts",
    "validate:vertical": "npx tsx scripts/validate-vertical.ts",
    "validate:all": "npm run validate:sites && npm run validate:vertical relocacion && npm run validate:vertical service-booking && npm run validate:vertical hospitality && npm run validate:vertical portfolio-professional",
    "generate:site": "npx tsx scripts/generate-site.ts",
    "generate:preview": "npx tsx scripts/generate-preview.ts",
    "import:leads": "npx tsx scripts/import-leads.ts",
    "deploy:setup": "npx tsx scripts/deploy-setup.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.90.19",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "postcss": "^8.5.9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.69.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@opennextjs/cloudflare": "^1.19.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
