{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/s/layout,_N_T_/s/[locale]/layout,_N_T_/s/[locale]/[site]/layout,_N_T_/s/[locale]/[site]/[[...page]]/layout,_N_T_/s/[locale]/[site]/[[...page]]/page,_N_T_/s/es/nexa-paraguay/faq"},"segmentPaths":["/_tree","/_full","/s/$d$locale/$d$site/$oc$page/__PAGE__","/s/$d$locale/$d$site/$oc$page","/s/$d$locale/$d$site","/s/$d$locale","/s","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"es\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0n2~88ua3acm-.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0bzupvr5gt3k9.js\"/><script src=\"/_next/static/chunks/09z8lfty.0pmt.js\" async=\"\"></script><script src=\"/_next/static/chunks/0n~dq4kpx9xxx.js\" async=\"\"></script><script src=\"/_next/static/chunks/0mu6w5jq7x8v_.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-0mj-j.lbx_1g1.js\" async=\"\"></script><script src=\"/_next/static/chunks/01xlw8hd842-c.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0pfe7f56-2izj.js\" async=\"\"></script><script src=\"/_next/static/chunks/0vyqd5j4oglno.js\" async=\"\"></script><script src=\"/_next/static/chunks/142rq-93oz_gl.js\" async=\"\"></script><link rel=\"preload\" href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&amp;family=Inter:wght@400;500;600;700&amp;display=swap\" as=\"style\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><title>Preguntas frecuentes — Nexa Paraguay</title><meta name=\"description\" content=\"Respuestas a las 15 preguntas más frecuentes sobre nuestro proceso, precios y programas.\"/><link rel=\"alternate\" hrefLang=\"nl\" href=\"/s/nl/nexa-paraguay/faq\"/><link rel=\"alternate\" hrefLang=\"en\" href=\"/s/en/nexa-paraguay/faq\"/><link rel=\"alternate\" hrefLang=\"de\" href=\"/s/de/nexa-paraguay/faq\"/><link rel=\"alternate\" hrefLang=\"es\" href=\"/s/es/nexa-paraguay/faq\"/><link rel=\"alternate\" hrefLang=\"x-default\" href=\"/s/en/nexa-paraguay/faq\"/><meta property=\"og:title\" content=\"Preguntas frecuentes — Nexa Paraguay\"/><meta property=\"og:description\" content=\"Respuestas a las 15 preguntas más frecuentes sobre nuestro proceso, precios y programas.\"/><meta property=\"og:locale\" content=\"es\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"Preguntas frecuentes — Nexa Paraguay\"/><meta name=\"twitter:description\" content=\"Respuestas a las 15 preguntas más frecuentes sobre nuestro proceso, precios y programas.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.152ctljmxrwid.ico\" sizes=\"32x32\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><style>:root {\n  --primary: #1B2A4A;\n  --primary-foreground: #ffffff;\n  --secondary: #C9A96E;\n  --secondary-foreground: #ffffff;\n  --accent: #C9A96E;\n  --accent-foreground: #1B2A4A;\n  --background: #FFFFFF;\n  --surface: #FFFFFF;\n  --surface-light: #F7F4EC;\n  --text: #1B2A4A;\n  --text-light: #333333;\n  --text-muted: #6B6B6B;\n  --success: #4a7c59;\n  --error: #c0392b;\n  --warning: #f39c12;\n  --font-heading: 'Playfair Display', serif;\n  --font-body: 'Inter', sans-serif;\n  --font-accent: 'Playfair Display', serif;\n  --heading-weight: 700;\n  --body-weight: 400;\n  --heading-transform: none;\n  --spacing-xs: 4px;\n  --spacing-sm: 8px;\n  --spacing-md: 16px;\n  --spacing-lg: 24px;\n  --spacing-xl: 32px;\n  --spacing-2xl: 48px;\n  --spacing-3xl: 64px;\n  --spacing-4xl: 96px;\n  --radius-none: 0px;\n  --radius-sm: 4px;\n  --radius-md: 8px;\n  --radius-lg: 16px;\n  --radius-full: 9999px;\n  --shadow-card: 0 2px 8px rgba(0,0,0,0.08);\n  --shadow-card-hover: 0 8px 24px rgba(0,0,0,0.12);\n  --shadow-button: 0 4px 12px rgba(0,0,0,0.15);\n  --shadow-nav: 0 2px 4px rgba(0,0,0,0.06);\n  --text-h1: 3rem;\n  --text-h2: 2.25rem;\n  --text-h3: 1.5rem;\n  --text-h4: 1.25rem;\n  --text-body: 1rem;\n  --text-small: 0.875rem;\n  --text-caption: 0.75rem;\n  --leading-tight: 1.2;\n  --leading-normal: 1.5;\n  --leading-relaxed: 1.75;\n  --transition-fast: 0.2s;\n  --transition-normal: 0.3s;\n  --transition-slow: 0.6s;\n}</style><link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&amp;family=Inter:wght@400;500;600;700&amp;display=swap\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"LocalBusiness\",\"name\":\"nexa-paraguay\",\"url\":\"http://localhost:3000/s/es/nexa-paraguay/faq\",\"areaServed\":\"Paraguay\",\"email\":\"hola@nexaparaguay.com\",\"telephone\":\"595000000000\",\"inLanguage\":\"es\",\"description\":\"Respuestas a las 15 preguntas más frecuentes sobre nuestro proceso, precios y programas.\"}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"¿Cuánto tiempo toma todo el proceso?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Tramitación presencial en un día. Emisión de residencia y cédula: 45–60 días. Constitución de sociedad y cuenta bancaria: 2–4 semanas. Total: 8–12 semanas.\"}},{\"@type\":\"Question\",\"name\":\"¿Cuántos viajes necesito hacer a Paraguay?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nuestro programa está diseñado para que un solo viaje sea suficiente.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué incluye el precio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Honorarios profesionales, IVA, tasas oficiales, coordinación bancaria, tour inmobiliario y asesoramiento integral. No hay cargos adicionales en el trámite regular.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué NO está incluido?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Vuelos internacionales, alojamiento, gastos personales, traducciones juradas y apostillas en su país de origen.\"}},{\"@type\":\"Question\",\"name\":\"¿Necesito hablar español?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. Nuestro equipo le acompaña en todo momento y la comunicación comercial es en neerlandés, inglés y alemán.\"}},{\"@type\":\"Question\",\"name\":\"¿Puedo abrir una cuenta bancaria siendo extranjero?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sí. Es el proceso más complejo, pero preparamos su perfil financiero y coordinamos con la entidad para maximizar las probabilidades de aprobación.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué tipo de sociedad se constituye?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nuestro equipo legal recomienda el tipo societario más conveniente (generalmente EAS o SA) según su caso.\"}},{\"@type\":\"Question\",\"name\":\"¿El proceso es 100% legal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Absolutamente. Estricto apego a la legislación paraguaya e internacional.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué pasa si falta algún documento?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Lo detectamos antes de su viaje. Nuestra validación previa garantiza que llegue con todo en orden.\"}},{\"@type\":\"Question\",\"name\":\"¿Ofrecen garantía de apertura bancaria?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"La decisión final es del banco. Garantizamos preparación profesional y coordinación institucional.\"}},{\"@type\":\"Question\",\"name\":\"¿Puedo traer a mi familia?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sí. Cada miembro requiere su propio proceso de residencia.\"}},{\"@type\":\"Question\",\"name\":\"¿Cómo se realiza el pago?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pago anticipado por transferencia bancaria. Sin cargos adicionales.\"}},{\"@type\":\"Question\",\"name\":\"¿Puedo contratar solo la residencia?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Programas integrales por diseño. Contáctenos para su caso específico.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué pasa después del primer año (Investor)?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Propuesta de continuidad adaptada a sus necesidades actuales.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué pasa si cambian las leyes durante mi proceso?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Monitoreamos el entorno regulatorio y le informamos inmediatamente si hay cambios relevantes.\"}}]}</script><div class=\"min-h-screen\" style=\"font-family:var(--font-body);background-color:var(--background);color:var(--text)\"><header class=\"sticky top-0 z-50 bg-[var(--surface)] shadow-nav\"><div class=\"mx-auto w-full px-4 sm:px-6 lg:px-8 max-w-7xl\"><div class=\"flex h-[70px] items-center justify-between sm:h-20\"><a href=\"#\" class=\"text-xl font-bold text-[var(--text)]\" style=\"font-family:var(--font-heading)\">Nexa Paraguay</a><nav class=\"hidden items-center gap-6 md:flex\"><a href=\"/s/es/nexa-paraguay\" class=\"text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--secondary)]\">Inicio</a><a href=\"/s/es/nexa-paraguay/programas\" class=\"text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--secondary)]\">Programas</a><a href=\"/s/es/nexa-paraguay/por-que-paraguay\" class=\"text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--secondary)]\">Por qué Paraguay</a><a href=\"/s/es/nexa-paraguay/proceso\" class=\"text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--secondary)]\">Proceso</a><a href=\"/s/es/nexa-paraguay/sobre\" class=\"text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--secondary)]\">Sobre Nexa</a><a href=\"/s/es/nexa-paraguay/faq\" class=\"text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--secondary)]\">FAQ</a><a href=\"/s/es/nexa-paraguay/blog\" class=\"text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--secondary)]\">Blog</a><a href=\"/s/es/nexa-paraguay/contacto\" class=\"text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--secondary)]\">Contacto</a><a href=\"/s/es/nexa-paraguay/contacto\" class=\"inline-flex items-center justify-center font-medium transition-all duration-normal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-[var(--secondary)] text-white shadow-button hover:shadow-card-hover hover:-translate-y-0.5 h-9 px-4 text-sm rounded-md\">Agendar consulta</a></nav><button class=\"flex h-10 w-10 items-center justify-center rounded-md md:hidden\" aria-label=\"Menu\"><span class=\"text-2xl text-[var(--text)]\">☰</span></button></div></div></header><section class=\"relative flex min-h-[70vh] items-center justify-center overflow-hidden bg-[var(--primary)]\"><div class=\"mx-auto w-full px-4 sm:px-6 lg:px-8 max-w-7xl relative z-10 py-20 text-center\"><h1 class=\"mb-6 text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl\" style=\"font-family:var(--font-heading);font-weight:var(--heading-weight);color:var(--primary-foreground);text-transform:var(--heading-transform)\">Preguntas frecuentes</h1><p class=\"mx-auto mb-10 max-w-2xl text-lg sm:text-xl\" style=\"font-family:var(--font-body);color:var(--text-light)\">Las respuestas que nuestros clientes más consultan.</p><div class=\"flex flex-col items-center justify-center gap-4 sm:flex-row\"><a href=\"#contacto\" class=\"inline-flex items-center justify-center font-medium transition-all duration-normal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-[var(--secondary)] text-white shadow-button hover:shadow-card-hover hover:-translate-y-0.5 h-13 px-8 text-lg rounded-lg\"></a></div></div></section><section class=\"bg-[var(--surface)] py-16 sm:py-20\"><div class=\"mx-auto w-full px-4 sm:px-6 lg:px-8 max-w-5xl\"><div class=\"animate-on-scroll mb-12 text-center\"><h2 class=\"text-3xl sm:text-4xl leading-tight font-[var(--font-heading)] text-[var(--text)]\" style=\"text-transform:var(--heading-transform)\">Preguntas frecuentes</h2></div><div class=\"mx-auto max-w-3xl\"><div class=\"animate-on-scroll stagger-1\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Cuánto tiempo toma todo el proceso?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Tramitación presencial en un día. Emisión de residencia y cédula: 45–60 días. Constitución de sociedad y cuenta bancaria: 2–4 semanas. Total: 8–12 semanas.</p></div></div></div><div class=\"animate-on-scroll stagger-2\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Cuántos viajes necesito hacer a Paraguay?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Nuestro programa está diseñado para que un solo viaje sea suficiente.</p></div></div></div><div class=\"animate-on-scroll stagger-3\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Qué incluye el precio?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Honorarios profesionales, IVA, tasas oficiales, coordinación bancaria, tour inmobiliario y asesoramiento integral. No hay cargos adicionales en el trámite regular.</p></div></div></div><div class=\"animate-on-scroll stagger-4\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Qué NO está incluido?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Vuelos internacionales, alojamiento, gastos personales, traducciones juradas y apostillas en su país de origen.</p></div></div></div><div class=\"animate-on-scroll stagger-5\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Necesito hablar español?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">No. Nuestro equipo le acompaña en todo momento y la comunicación comercial es en neerlandés, inglés y alemán.</p></div></div></div><div class=\"animate-on-scroll stagger-6\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Puedo abrir una cuenta bancaria siendo extranjero?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Sí. Es el proceso más complejo, pero preparamos su perfil financiero y coordinamos con la entidad para maximizar las probabilidades de aprobación.</p></div></div></div><div class=\"animate-on-scroll stagger-7\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Qué tipo de sociedad se constituye?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Nuestro equipo legal recomienda el tipo societario más conveniente (generalmente EAS o SA) según su caso.</p></div></div></div><div class=\"animate-on-scroll stagger-8\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿El proceso es 100% legal?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Absolutamente. Estricto apego a la legislación paraguaya e internacional.</p></div></div></div><div class=\"animate-on-scroll stagger-9\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Qué pasa si falta algún documento?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Lo detectamos antes de su viaje. Nuestra validación previa garantiza que llegue con todo en orden.</p></div></div></div><div class=\"animate-on-scroll stagger-10\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Ofrecen garantía de apertura bancaria?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">La decisión final es del banco. Garantizamos preparación profesional y coordinación institucional.</p></div></div></div><div class=\"animate-on-scroll\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Puedo traer a mi familia?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Sí. Cada miembro requiere su propio proceso de residencia.</p></div></div></div><div class=\"animate-on-scroll\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Cómo se realiza el pago?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Pago anticipado por transferencia bancaria. Sin cargos adicionales.</p></div></div></div><div class=\"animate-on-scroll\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Puedo contratar solo la residencia?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Programas integrales por diseño. Contáctenos para su caso específico.</p></div></div></div><div class=\"animate-on-scroll\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Qué pasa después del primer año (Investor)?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Propuesta de continuidad adaptada a sus necesidades actuales.</p></div></div></div><div class=\"animate-on-scroll\"><div class=\"border-b border-[var(--surface-light)]\"><button class=\"flex w-full items-center justify-between py-5 text-left transition-colors hover:text-[var(--secondary)]\"><span class=\"pr-4 font-medium text-[var(--text)]\">¿Qué pasa si cambian las leyes durante mi proceso?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down flex-shrink-0 text-[var(--text-muted)] transition-transform duration-normal\" aria-hidden=\"true\" style=\"transform:rotate(0deg)\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-normal\" style=\"max-height:0px;opacity:0\"><p class=\"pb-5 leading-relaxed text-[var(--text-muted)]\">Monitoreamos el entorno regulatorio y le informamos inmediatamente si hay cambios relevantes.</p></div></div></div></div></div></section><section class=\"relative overflow-hidden py-16\" style=\"background:linear-gradient(135deg, var(--secondary) 0%, var(--primary) 100%)\"><div class=\"absolute inset-0 opacity-[0.06]\" style=\"background-image:radial-gradient(circle at 30% 40%, rgba(255,255,255,0.5) 0%, transparent 50%)\"></div><div class=\"mx-auto w-full px-4 sm:px-6 lg:px-8 max-w-7xl relative z-10 text-center\"><div class=\"animate-on-scroll\"><h2 class=\"mb-4 text-3xl font-bold text-[var(--secondary-foreground)] sm:text-