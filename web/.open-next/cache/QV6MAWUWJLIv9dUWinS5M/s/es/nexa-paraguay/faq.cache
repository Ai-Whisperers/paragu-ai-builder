32px;\n  --spacing-2xl: 48px;\n  --spacing-3xl: 64px;\n  --spacing-4xl: 96px;\n  --radius-none: 0px;\n  --radius-sm: 4px;\n  --radius-md: 8px;\n  --radius-lg: 16px;\n  --radius-full: 9999px;\n  --shadow-card: 0 2px 8px rgba(0,0,0,0.08);\n  --shadow-card-hover: 0 8px 24px rgba(0,0,0,0.12);\n  --shadow-button: 0 4px 12px rgba(0,0,0,0.15);\n  --shadow-nav: 0 2px 4px rgba(0,0,0,0.06);\n  --text-h1: 3rem;\n  --text-h2: 2.25rem;\n  --text-h3: 1.5rem;\n  --text-h4: 1.25rem;\n  --text-body: 1rem;\n  --text-small: 0.875rem;\n  --text-caption: 0.75rem;\n  --leading-tight: 1.2;\n  --leading-normal: 1.5;\n  --leading-relaxed: 1.75;\n  --transition-fast: 0.2s;\n  --transition-normal: 0.3s;\n  --transition-slow: 0.6s;\n}3:Tcce,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"¿Cuánto tiempo toma todo el proceso?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Tramitación presencial en un día. Emisión de residencia y cédula: 45–60 días. Constitución de sociedad y cuenta bancaria: 2–4 semanas. Total: 8–12 semanas.\"}},{\"@type\":\"Question\",\"name\":\"¿Cuántos viajes necesito hacer a Paraguay?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nuestro programa está diseñado para que un solo viaje sea suficiente.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué incluye el precio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Honorarios profesionales, IVA, tasas oficiales, coordinación bancaria, tour inmobiliario y asesoramiento integral. No hay cargos adicionales en el trámite regular.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué NO está incluido?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Vuelos internacionales, alojamiento, gastos personales, traducciones juradas y apostillas en su país de origen.\"}},{\"@type\":\"Question\",\"name\":\"¿Necesito hablar español?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. Nuestro equipo le acompaña en todo momento y la comunicación comercial es en neerlandés, inglés y alemán.\"}},{\"@type\":\"Question\",\"name\":\"¿Puedo abrir una cuenta bancaria siendo extranjero?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sí. Es el proceso más complejo, pero preparamos su perfil financiero y coordinamos con la entidad para maximizar las probabilidades de aprobación.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué tipo de sociedad se constituye?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nuestro equipo legal recomienda el tipo societario más conveniente (generalmente EAS o SA) según su caso.\"}},{\"@type\":\"Question\",\"name\":\"¿El proceso es 100% legal?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Absolutamente. Estricto apego a la legislación paraguaya e internacional.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué pasa si falta algún documento?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Lo detectamos antes de su viaje. Nuestra validación previa garantiza que llegue con todo en orden.\"}},{\"@type\":\"Question\",\"name\":\"¿Ofrecen garantía de apertura bancaria?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"La decisión final es del banco. Garantizamos preparación profesional y coordinación institucional.\"}},{\"@type\":\"Question\",\"name\":\"¿Puedo traer a mi familia?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sí. Cada miembro requiere su propio proceso de residencia.\"}},{\"@type\":\"Question\",\"name\":\"¿Cómo se realiza el pago?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pago anticipado por transferencia bancaria. Sin cargos adicionales.\"}},{\"@type\":\"Question\",\"name\":\"¿Puedo contratar solo la residencia?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Programas integrales por diseño. Contáctenos para su caso específico.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué pasa después del primer año (Investor)?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Propuesta de continuidad adaptada a sus necesidades actuales.\"}},{\"@type\":\"Question\",\"name\":\"¿Qué pasa si cambian las leyes durante mi proceso?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Monitoreamos el entorno regulatorio y le informamos inmediatamente si hay cambios relevantes.\"}}]}0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"style\",null,{\"dangerouslySetInnerHTML\":{\"__html\":\"$2\"}}],[\"$\",\"link\",null,{\"rel\":\"stylesheet\",\"href\":\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap\"}],[[\"$\",\"script\",\"0\",{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"LocalBusiness\\\",\\\"name\\\":\\\"nexa-paraguay\\\",\\\"url\\\":\\\"http://localhost:3000/s/es/nexa-paraguay/faq\\\",\\\"areaServed\\\":\\\"Paraguay\\\",\\\"email\\\":\\\"hola@nexaparaguay.com\\\",\\\"telephone\\\":\\\"595000000000\\\",\\\"inLanguage\\\":\\\"es\\\",\\\"description\\\":\\\"Respuestas a las 15 preguntas más frecuentes sobre nuestro proceso, precios y programas.\\\"}\"}}],[\"$\",\"script\",\"1\",{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$3\"}}]],\"$L4\",\"$undefined\",\"$L5\",false],[\"$L6\",\"$L7\",\"$L8\"],\"$L9\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"QV6MAWUWJLIv9dUWinS5M\"}\n4:[\"$\",\"div\",null,{\"className\":\"min-h-screen\",\"style\":{\"fontFamily\":\"var(--font-body)\",\"backgroundColor\":\"var(--background)\",\"color\":\"var(--text)\"},\"children\":[[\"$\",\"$La\",\"header-0\",{\"businessName\":\"Nexa Paraguay\",\"navItems\":[{\"label\":\"Inicio\",\"href\":\"/s/es/nexa-paraguay\"},{\"label\":\"Programas\",\"href\":\"/s/es/nexa-paraguay/programas\"},{\"label\":\"Por qué Paraguay\",\"href\":\"/s/es/nexa-paraguay/por-que-paraguay\"},{\"label\":\"Proceso\",\"href\":\"/s/es/nexa-paraguay/proceso\"},{\"label\":\"Sobre Nexa\",\"href\":\"/s/es/nexa-paraguay/sobre\"},{\"label\":\"FAQ\",\"href\":\"/s/es/nexa-parag