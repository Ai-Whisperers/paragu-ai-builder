# Nexa Paraguay — example production env
# Copy into Cloudflare Pages project settings. Never commit real values.

NEXT_PUBLIC_APP_URL=https://nexaparaguay.com

# Supabase (leads table)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Analytics (GA4) — injected only after user consents via cookie banner
NEXT_PUBLIC_GA4_ID=G-XXXXXXXX

# CRM (HubSpot forms API)
CRM_PORTAL_ID=123456
CRM_ENDPOINT=your-form-guid

# Email (Mailchimp) — US or EU datacenter suffix included in the API key itself
EMAIL_API_KEY=xxxxxxxxxxxxxxxxxx-us1
EMAIL_LIST_ID=your-audience-id
EMAIL_FROM_ADDRESS=hola@nexaparaguay.com
EMAIL_FROM_NAME=Nexa Paraguay

# Transactional email (optional — Resend for welcome autoresponder)
EMAIL_TRANSACTIONAL_KEY=
